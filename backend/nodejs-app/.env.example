# Application Configuration
NODE_ENV=development
PORT=3000
APP_NAME=SaaS WhatsApp Notifications
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_whatsapp_db
DB_USER=username
DB_PASSWORD=password
DB_DIALECT=postgres

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_MAX_AGE=86400000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Shopify Configuration
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
SHOPIFY_API_VERSION=2023-10

# WhatsApp Configuration
WHATSAPP_SESSION_PATH=./whatsapp_sessions
QR_CODE_EXPIRY_MINUTES=5
WHATSAPP_TIMEOUT_MS=60000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
SMTP_TLS=true

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE=10485760

# Webhook Configuration
WEBHOOK_TIMEOUT_MS=30000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_WHATSAPP_VERIFICATION=true
ENABLE_ANALYTICS=true
ENABLE_ADMIN_PANEL=true

# Payment Configuration (for future use)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090

