{
  "name": "saas-whatsapp-notifications",
  "version": "1.0.0",
  "description": "SaaS WhatsApp Notification System with Shopify Integration",
  "main": "app.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha --recursive tests",
    "test:unit": "mocha tests/unit --recursive",
    "test:integration": "mocha tests/integration --recursive",
    "test:performance": "mocha tests/performance --recursive",
    "test:coverage": "nyc mocha --recursive tests",
    "test:watch": "mocha --recursive tests --watch",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t saas-whatsapp-backend .",
    "docker:run": "docker run -p 3000:3000 saas-whatsapp-backend"
  },
  "keywords": [
    "saas",
    "whatsapp",
    "shopify",
    "notifications",
    "baileys",
    "express",
    "ejs"
  ],
  "author": "SaaS WhatsApp Team",
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "connect-flash": "^0.1.1",
    "connect-session-sequelize": "^8.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-flash": "^0.0.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.7.0",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "chai": "^5.2.0",
    "concurrently": "^9.1.0",
    "mocha": "^11.6.0",
    "nodemon": "^3.1.9",
    "nyc": "^15.1.0",
    "supertest": "^7.1.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript",
    "all": true,
    "check-coverage": true,
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "exclude": [
      "tests/**",
      "scripts/**",
      "node_modules/**"
    ]
  }
}
