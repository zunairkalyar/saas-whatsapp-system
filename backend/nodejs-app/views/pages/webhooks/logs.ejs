<div class="container-fluid">
    <h1 class="mb-4">Webhook Logs</h1>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Recent Webhook Activity</h5>
                    <p class="card-text">Total logs: <%= totalLogs %></p>
                </div>
                <div class="card-body">
                    <% if (logs && logs.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Timestamp</th>
                                        <th>Shop Domain</th>
                                        <th>Topic</th>
                                        <th>Order ID</th>
                                        <th>Status</th>
                                        <th>Processing Time</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% logs.forEach(log => { %>
                                        <tr>
                                            <td><%= new Date(log.created_at).toLocaleString() %></td>
                                            <td><%= log.shop_domain %></td>
                                            <td><span class="badge badge-info"><%= log.webhook_topic %></span></td>
                                            <td><%= log.shopify_order_id || 'N/A' %></td>
                                            <td>
                                                <% if (log.processing_status === 'processed') { %>
                                                    <span class="badge badge-success">Processed</span>
                                                <% } else if (log.processing_status === 'failed') { %>
                                                    <span class="badge badge-danger">Failed</span>
                                                <% } else if (log.processing_status === 'ignored') { %>
                                                    <span class="badge badge-warning">Ignored</span>
                                                <% } else { %>
                                                    <span class="badge badge-secondary">Pending</span>
                                                <% } %>
                                            </td>
                                            <td><%= log.processing_time_ms ? log.processing_time_ms + 'ms' : 'N/A' %></td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" onclick="viewWebhookDetails('<%= log.id %>')">
                                                    <i class="fas fa-eye"></i> View
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <% if (totalPages > 1) { %>
                            <nav aria-label="Webhook logs pagination">
                                <ul class="pagination justify-content-center">
                                    <% if (hasPrevPage) { %>
                                        <li class="page-item">
                                            <a class="page-link" href="?page=<%= prevPage %>">Previous</a>
                                        </li>
                                    <% } %>
                                    
                                    <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                            <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    
                                    <% if (hasNextPage) { %>
                                        <li class="page-item">
                                            <a class="page-link" href="?page=<%= nextPage %>">Next</a>
                                        </li>
                                    <% } %>
                                </ul>
                            </nav>
                        <% } %>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <h5>No webhook logs found</h5>
                            <p class="text-muted">Webhook logs will appear here once Shopify starts sending events to your webhook endpoint.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for webhook details -->
<div class="modal fade" id="webhookDetailsModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Webhook Details</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="webhookDetailsContent">
                    Loading...
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        padding: 1rem;
    }
    .card-title {
        margin-bottom: 0.5rem;
        font-size: 1.25rem;
        font-weight: 500;
    }
    .card-text {
        margin-bottom: 0;
        color: #6c757d;
    }
    .table-responsive {
        border-radius: 0.375rem;
    }
    .table {
        margin-bottom: 0;
    }
    .table th {
        border-top: none;
        font-weight: 600;
        background-color: #f8f9fa;
    }
    .badge {
        font-size: 0.75rem;
        padding: 0.375rem 0.5rem;
    }
    .badge-info {
        background-color: #17a2b8;
    }
    .badge-success {
        background-color: #28a745;
    }
    .badge-danger {
        background-color: #dc3545;
    }
    .badge-warning {
        background-color: #ffc107;
        color: #212529;
    }
    .badge-secondary {
        background-color: #6c757d;
    }
    .btn-outline-primary {
        color: #007bff;
        border-color: #007bff;
    }
    .btn-outline-primary:hover {
        background-color: #007bff;
        color: #fff;
    }
    .pagination {
        margin-bottom: 0;
    }
    .page-link {
        color: #007bff;
    }
    .page-item.active .page-link {
        background-color: #007bff;
        border-color: #007bff;
    }
    .modal-lg {
        max-width: 800px;
    }
</style>

<script>
function viewWebhookDetails(logId) {
    // TODO: Implement AJAX call to fetch webhook details
    document.getElementById('webhookDetailsContent').innerHTML = `
        <p><strong>Webhook ID:</strong> ${logId}</p>
        <p>Detailed webhook information will be loaded here via AJAX.</p>
    `;
    $('#webhookDetailsModal').modal('show');
}

// Bootstrap modal functionality (simplified)
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('webhookDetailsModal');
    const closeButtons = modal.querySelectorAll('[data-dismiss="modal"]');
    
    closeButtons.forEach(button => {
        button.addEventListener('click', function() {
            modal.style.display = 'none';
        });
    });
    
    window.$ = window.$ || {};
    window.$.fn = window.$.fn || {};
    window.$.fn.modal = function(action) {
        if (action === 'show') {
            modal.style.display = 'block';
        } else if (action === 'hide') {
            modal.style.display = 'none';
        }
        return this;
    };
    window.$ = function(selector) {
        return {
            modal: window.$.fn.modal
        };
    };
});
</script>

