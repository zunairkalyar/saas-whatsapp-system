<!-- Dashboard Overview Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card admin-stat-card border-left-primary">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Total Users
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats.totalUsers.toLocaleString() %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-2">
                    <small class="text-success">
                        <i class="fas fa-check-circle"></i>
                        <%= stats.activeUsers %> active
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card admin-stat-card border-left-success">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Active Subscriptions
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats.activeSubscriptions.toLocaleString() %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-credit-card fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-2">
                    <small class="text-muted">
                        of <%= stats.totalSubscriptions %> total
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card admin-stat-card border-left-info">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Messages This Month
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats.messagesThisMonth.toLocaleString() %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fab fa-whatsapp fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-2">
                    <small class="text-info">
                        <%= stats.messagesToday %> today
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card admin-stat-card border-left-warning">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Total Messages
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats.totalMessages.toLocaleString() %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-envelope fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-2">
                    <small class="text-muted">
                        All time total
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-bolt"></i> Quick Actions
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <a href="/admin/users" class="btn btn-outline-primary btn-block">
                            <i class="fas fa-users"></i> Manage Users
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="/admin/subscriptions" class="btn btn-outline-success btn-block">
                            <i class="fas fa-credit-card"></i> View Subscriptions
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="/admin/webhooks" class="btn btn-outline-info btn-block">
                            <i class="fas fa-webhook"></i> Webhook Logs
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="/admin/system" class="btn btn-outline-warning btn-block">
                            <i class="fas fa-server"></i> System Status
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="card">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-chart-line"></i> System Activity Overview
                </h6>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="activityChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-exclamation-triangle"></i> System Alerts
                </h6>
            </div>
            <div class="card-body">
                <div class="alert alert-warning alert-sm" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Notice:</strong> 3 users approaching message limits
                </div>
                
                <div class="alert alert-info alert-sm" role="alert">
                    <i class="fas fa-info-circle"></i>
                    <strong>Info:</strong> System backup completed successfully
                </div>
                
                <div class="alert alert-success alert-sm" role="alert">
                    <i class="fas fa-check-circle"></i>
                    <strong>Success:</strong> All services running normally
                </div>
                
                <div class="text-center mt-3">
                    <a href="/admin/system" class="btn btn-sm btn-outline-primary">
                        View All Alerts
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Users and Activity -->
<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-user-plus"></i> Recent User Registrations
                </h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Plan</th>
                                <th>Registered</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-2">
                                            <i class="fas fa-user-circle text-muted"></i>
                                        </div>
                                        <div>
                                            <div class="font-weight-bold">john@example.com</div>
                                            <small class="text-muted">John Doe</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge bg-success">Free</span></td>
                                <td><small>2 hours ago</small></td>
                                <td><span class="badge bg-success">Active</span></td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-2">
                                            <i class="fas fa-user-circle text-muted"></i>
                                        </div>
                                        <div>
                                            <div class="font-weight-bold">jane@store.com</div>
                                            <small class="text-muted">Jane Smith</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge bg-primary">Basic</span></td>
                                <td><small>5 hours ago</small></td>
                                <td><span class="badge bg-warning">Pending</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-center">
                    <a href="/admin/users" class="btn btn-sm btn-outline-primary">
                        View All Users
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-bell"></i> Recent System Events
                </h6>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker bg-success"></div>
                        <div class="timeline-content">
                            <h6 class="timeline-title">Webhook processed successfully</h6>
                            <p class="timeline-text">Order #1234 from store.myshopify.com</p>
                            <small class="text-muted">2 minutes ago</small>
                        </div>
                    </div>
                    
                    <div class="timeline-item">
                        <div class="timeline-marker bg-info"></div>
                        <div class="timeline-content">
                            <h6 class="timeline-title">WhatsApp message sent</h6>
                            <p class="timeline-text">Order confirmation to +1234567890</p>
                            <small class="text-muted">5 minutes ago</small>
                        </div>
                    </div>
                    
                    <div class="timeline-item">
                        <div class="timeline-marker bg-warning"></div>
                        <div class="timeline-content">
                            <h6 class="timeline-title">User approaching limit</h6>
                            <p class="timeline-text">user@example.com (95/100 messages)</p>
                            <small class="text-muted">10 minutes ago</small>
                        </div>
                    </div>
                    
                    <div class="timeline-item">
                        <div class="timeline-marker bg-primary"></div>
                        <div class="timeline-content">
                            <h6 class="timeline-title">New subscription created</h6>
                            <p class="timeline-text">Basic plan for newuser@shop.com</p>
                            <small class="text-muted">1 hour ago</small>
                        </div>
                    </div>
                </div>
                
                <div class="text-center">
                    <a href="/admin/system" class="btn btn-sm btn-outline-primary">
                        View All Events
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Simple chart for activity overview (you can replace with Chart.js or similar)
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('activityChart');
    if (ctx) {
        // Placeholder for chart implementation
        ctx.getContext('2d').fillText('Activity Chart - Implement with Chart.js', 10, 50);
    }
});
</script>

