<div class="container-fluid">
    <h1 class="mb-4">WhatsApp Integration</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="fab fa-whatsapp"></i> WhatsApp Connection Status
                    </h5>
                </div>
                <div class="card-body">
                    <div id="connection-status">
                        <% if (whatsappSession.connection_status === 'connected') { %>
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle"></i>
                                <strong>Connected!</strong> Your WhatsApp is ready to send notifications.
                                <% if (whatsappSession.last_connected) { %>
                                    <br><small>Connected on: <%= new Date(whatsappSession.last_connected).toLocaleString() %></small>
                                <% } %>
                            </div>
                            
                            <div class="mt-3">
                                <form action="/whatsapp/disconnect" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-unlink"></i> Disconnect WhatsApp
                                    </button>
                                </form>
                            </div>
                        <% } else if (whatsappSession.connection_status === 'qr_generated') { %>
                            <div class="alert alert-warning">
                                <i class="fas fa-qrcode"></i>
                                <strong>QR Code Generated!</strong> Please scan the QR code below with your WhatsApp mobile app.
                            </div>
                            
                            <% if (whatsappSession.qr_code) { %>
                                <div class="text-center mb-3">
                                    <img src="<%= whatsappSession.qr_code %>" alt="WhatsApp QR Code" class="qr-code-image">
                                    <p class="text-muted mt-2">
                                        <small>
                                            <i class="fas fa-clock"></i> 
                                            QR code expires in <span id="qr-countdown">5:00</span>
                                        </small>
                                    </p>
                                </div>
                            <% } %>
                            
                            <div class="mt-3">
                                <form action="/whatsapp/refresh-qr" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-secondary">
                                        <i class="fas fa-sync"></i> Refresh QR Code
                                    </button>
                                </form>
                                <form action="/whatsapp/disconnect" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-outline-danger">
                                        <i class="fas fa-times"></i> Cancel
                                    </button>
                                </form>
                            </div>
                        <% } else if (whatsappSession.connection_status === 'error') { %>
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Connection Error!</strong> 
                                <% if (whatsappSession.error_message) { %>
                                    <%= whatsappSession.error_message %>
                                <% } else { %>
                                    An error occurred while connecting to WhatsApp.
                                <% } %>
                            </div>
                            
                            <div class="mt-3">
                                <form action="/whatsapp/connect" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-redo"></i> Try Again
                                    </button>
                                </form>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i>
                                <strong>Not Connected</strong> Connect your WhatsApp to start sending automatic notifications.
                            </div>
                            
                            <div class="mt-3">
                                <form action="/whatsapp/connect" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-success btn-lg">
                                        <i class="fab fa-whatsapp"></i> Connect WhatsApp
                                    </button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <% if (whatsappSession.connection_status === 'connected') { %>
                <div class="card mt-4">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="fas fa-paper-plane"></i> Send Test Message
                        </h5>
                    </div>
                    <div class="card-body">
                        <form action="/whatsapp/test-message" method="POST">
                            <div class="form-group">
                                <label for="phoneNumber">Phone Number</label>
                                <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber" 
                                       placeholder="+1234567890" required>
                                <small class="form-text text-muted">Include country code (e.g., +1 for US/Canada)</small>
                            </div>
                            <div class="form-group">
                                <label for="message">Message</label>
                                <textarea class="form-control" id="message" name="message" rows="3" 
                                          placeholder="Enter your test message here..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Send Test Message
                            </button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="fas fa-info-circle"></i> How It Works
                    </h5>
                </div>
                <div class="card-body">
                    <ol class="setup-steps">
                        <li>
                            <strong>Connect WhatsApp</strong>
                            <p>Click "Connect WhatsApp" to generate a QR code.</p>
                        </li>
                        <li>
                            <strong>Scan QR Code</strong>
                            <p>Open WhatsApp on your phone, go to Settings > Linked Devices, and scan the QR code.</p>
                        </li>
                        <li>
                            <strong>Start Receiving Notifications</strong>
                            <p>Once connected, your customers will automatically receive WhatsApp notifications for Shopify orders.</p>
                        </li>
                    </ol>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="fas fa-shield-alt"></i> Security & Privacy
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="security-features">
                        <li><i class="fas fa-check text-success"></i> Your WhatsApp session is completely isolated</li>
                        <li><i class="fas fa-check text-success"></i> Messages are sent from your own WhatsApp account</li>
                        <li><i class="fas fa-check text-success"></i> No access to your personal messages</li>
                        <li><i class="fas fa-check text-success"></i> You can disconnect at any time</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .qr-code-image {
        max-width: 300px;
        border: 2px solid #ddd;
        border-radius: 8px;
        padding: 10px;
        background: white;
    }
    
    .setup-steps {
        padding-left: 20px;
    }
    
    .setup-steps li {
        margin-bottom: 15px;
    }
    
    .setup-steps li strong {
        color: #25D366;
    }
    
    .setup-steps li p {
        margin-top: 5px;
        margin-bottom: 0;
        color: #666;
        font-size: 0.9rem;
    }
    
    .security-features {
        list-style: none;
        padding-left: 0;
    }
    
    .security-features li {
        margin-bottom: 10px;
        font-size: 0.9rem;
    }
    
    .security-features li i {
        margin-right: 8px;
    }
    
    .card {
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    
    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        padding: 1rem;
    }
    
    .card-title {
        margin-bottom: 0;
        font-size: 1.1rem;
        font-weight: 500;
    }
    
    .card-title i {
        margin-right: 8px;
        color: #25D366;
    }
    
    .btn-success {
        background-color: #25D366;
        border-color: #25D366;
    }
    
    .btn-success:hover {
        background-color: #1da851;
        border-color: #1da851;
    }
    
    .form-group {
        margin-bottom: 1rem;
    }
    
    .form-group label {
        font-weight: 500;
        margin-bottom: 0.5rem;
        display: block;
    }
    
    .form-control {
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
        width: 100%;
    }
    
    .form-control:focus {
        border-color: #25D366;
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(37, 211, 102, 0.25);
    }
    
    .form-text {
        font-size: 0.875rem;
        color: #6c757d;
        margin-top: 0.25rem;
    }
    
    #qr-countdown {
        font-weight: bold;
        color: #dc3545;
    }
</style>

<script>
// Auto-refresh connection status every 5 seconds
setInterval(async function() {
    try {
        const response = await fetch('/whatsapp/status');
        const data = await response.json();
        
        if (data.success && data.session) {
            // Update connection status if it has changed
            const currentStatus = '<%= whatsappSession.connection_status %>';
            if (data.session.connection_status !== currentStatus) {
                location.reload(); // Reload page to show updated status
            }
        }
    } catch (error) {
        console.error('Error checking connection status:', error);
    }
}, 5000);

// QR code countdown timer
<% if (whatsappSession.connection_status === 'qr_generated' && whatsappSession.qr_expires_at) { %>
    const qrExpiresAt = new Date('<%= whatsappSession.qr_expires_at %>');
    
    function updateCountdown() {
        const now = new Date();
        const timeLeft = qrExpiresAt - now;
        
        if (timeLeft <= 0) {
            document.getElementById('qr-countdown').textContent = 'Expired';
            return;
        }
        
        const minutes = Math.floor(timeLeft / 60000);
        const seconds = Math.floor((timeLeft % 60000) / 1000);
        
        document.getElementById('qr-countdown').textContent = 
            `${minutes}:${seconds.toString().padStart(2, '0')}`;
    }
    
    // Update countdown every second
    setInterval(updateCountdown, 1000);
    updateCountdown(); // Initial call
<% } %>
</script>

