<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="admin-body">
    <!-- Admin Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-sidebar-header">
            <h4><i class="fas fa-shield-alt"></i> Admin Panel</h4>
        </div>
        
        <nav class="admin-nav">
            <ul class="admin-nav-list">
                <li class="admin-nav-item">
                    <a href="/admin" class="admin-nav-link">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/users" class="admin-nav-link">
                        <i class="fas fa-users"></i>
                        <span>Users</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/subscriptions" class="admin-nav-link">
                        <i class="fas fa-credit-card"></i>
                        <span>Subscriptions</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/plans" class="admin-nav-link">
                        <i class="fas fa-layer-group"></i>
                        <span>Plans</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/analytics" class="admin-nav-link">
                        <i class="fas fa-chart-line"></i>
                        <span>Analytics</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/webhooks" class="admin-nav-link">
                        <i class="fas fa-webhook"></i>
                        <span>Webhooks</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/messages" class="admin-nav-link">
                        <i class="fab fa-whatsapp"></i>
                        <span>Messages</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/system" class="admin-nav-link">
                        <i class="fas fa-server"></i>
                        <span>System</span>
                    </a>
                </li>
                
                <% if (admin.role === 'super_admin') { %>
                <li class="admin-nav-item">
                    <a href="/admin/settings" class="admin-nav-link">
                        <i class="fas fa-cog"></i>
                        <span>Settings</span>
                    </a>
                </li>
                
                <li class="admin-nav-item">
                    <a href="/admin/admins" class="admin-nav-link">
                        <i class="fas fa-user-shield"></i>
                        <span>Admin Users</span>
                    </a>
                </li>
                <% } %>
            </ul>
        </nav>
        
        <div class="admin-sidebar-footer">
            <div class="admin-user-info">
                <div class="admin-user-avatar">
                    <i class="fas fa-user-circle"></i>
                </div>
                <div class="admin-user-details">
                    <div class="admin-user-name"><%= admin.firstName %> <%= admin.lastName %></div>
                    <div class="admin-user-role"><%= admin.role.replace('_', ' ').toUpperCase() %></div>
                </div>
            </div>
            
            <form action="/admin/logout" method="POST" class="admin-logout-form">
                <button type="submit" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="admin-main">
        <!-- Top Bar -->
        <div class="admin-topbar">
            <div class="admin-topbar-left">
                <button class="btn btn-link admin-sidebar-toggle" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="admin-page-title"><%= title %></h1>
            </div>
            
            <div class="admin-topbar-right">
                <div class="admin-notifications">
                    <button class="btn btn-link admin-notification-btn">
                        <i class="fas fa-bell"></i>
                        <span class="admin-notification-badge">3</span>
                    </button>
                </div>
                
                <div class="admin-user-menu">
                    <div class="dropdown">
                        <button class="btn btn-link dropdown-toggle admin-user-btn" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle"></i>
                            <%= admin.firstName %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/admin/profile"><i class="fas fa-user"></i> Profile</a></li>
                            <li><a class="dropdown-item" href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form action="/admin/logout" method="POST" class="d-inline">
                                    <button type="submit" class="dropdown-item">
                                        <i class="fas fa-sign-out-alt"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Content Area -->
        <div class="admin-content">
            <!-- Flash Messages -->
            <% if (messages && messages.length > 0) { %>
                <% messages.forEach(function(message) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> <%= message %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% }); %>
            <% } %>
            
            <% if (errors && errors.length > 0) { %>
                <% errors.forEach(function(error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% }); %>
            <% } %>
            
            <!-- Page Content -->
            <%- body %>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>

